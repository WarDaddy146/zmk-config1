#include "corne.dtsi"

&kscan0 {
    row-gpios = <&pro_micro 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
    col-gpios = <&pro_micro 21 GPIO_ACTIVE_HIGH>;
};
&default_transform {
    rows = <1>;
    columns = <1>;
    map = <RC(0,0)>;
};
